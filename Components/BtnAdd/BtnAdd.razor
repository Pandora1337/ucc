@using System.Threading.Tasks

@namespace ucc.Components.BtnAdd

<button type="button" @onclick="OnClick" style="@style" @ref="ElementReference"
        class="btn-custom btn-body d-flex flex-column align-items-center justify-content-center text-center bg-body-secondary border border-2 border-secondary rounded-4 @Class">
    @if (EnableChildContent)
    {
        @ChildContent
    }
    else
    {
        <div class="p-1">
            <i class="bi @ImgSrc upload-icon mb-2" aria-hidden="true" />
            <p class="btn-text text-body-secondary mb-0 fw-bold">@Text</p>
            <p class="btn-text text-body-secondary m-0 fw-light">@Subtext</p>
        </div>

        @*
        <div class="d-flex flex-column align-items-center justify-content-center p-2 gap-1 h-100 w-100">
            <img src="@ImgSrc" class="upload-icon flex-shrink-0" draggable="false" alt="Upload Icon">
            <p class="btn-text mb-0 fw-bold text-center flex-grow-1 d-flex align-items-center">@Text</p>
        </div> 
        *@
    }
</button>

@code {
    [Parameter] public bool EnableChildContent { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClicked { get; set; }

    [Parameter] public string ImgSrc { get; set; } = "bi-plus-square-fill";
    [Parameter] public string Text { get; set; } = "Add New";
    [Parameter] public string? style { get; set; }
    [Parameter] public string Subtext { get; set; } = "";
    [Parameter] public string Class { get; set; } = "border";

    public ElementReference ElementReference { get; private set; }

    private async Task OnClick()
    {
        if (OnClicked.HasDelegate)
        {
            await OnClicked.InvokeAsync();
        }
    }
}