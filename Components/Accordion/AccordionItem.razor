@namespace ucc.Components.Accordion

<div class="accordion-item" style="@style">
    <h2 class="accordion-header">
        <button type="button" class="accordion-button @(isShowing ? "" : "collapsed") @ClassBtn"
                aria-expanded="@isShowing" aria-controls="flush-collapseOne" @onclick="Toggle">
            @if (!string.IsNullOrEmpty(Icon))
            {
                <i class="bi @Icon me-2" aria-hidden="true" />
            }

            @Title
        </button>
    </h2>

    <div id="flush-collapseOne" class="bg-body-tertiary accordion-collapse collapse @(isShowing ? "show" : "") @ClassBody">
        <div class="accordion-body">
            @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string ClassBtn { get; set; } = "";
    [Parameter] public string ClassBody { get; set; } = "";
    [Parameter] public string style { get; set; } = "";
    [Parameter] public bool OpenOnStart { get; set; } = false;

    protected override void OnAfterRender(bool firstRender)
    {
        if (OpenOnStart && firstRender)
        {
            Open();
            StateHasChanged();
        }
    }

    private bool isShowing { get; set; } = false;

    public void Toggle()
    {
        isShowing = !isShowing;
    }

    public void Open()
    {
        isShowing = true;
    }

    public void Close()
    {
        isShowing = false;
    }

    public bool IsShowing()
    {
        return isShowing;
    }
}