@using ucc.Services;

@implements IDisposable

@namespace ucc.Components.Dropdown

@inject ucc.Services.ThemeService TS;

<div class="dropdown">
    <button type="button" class="btn dropdown-toggle d-flex align-items-center @cClass" @onblur="PanelBlurred"
            aria-expanded="@IsOpen" aria-label="@ariaTheme" title="@ariaTheme" @onclick="Toggle">
        <i class="bi @icon" aria-hidden="true"></i>
    </button>

    <ul class="dropdown-menu @(IsOpen ? "show" : null)">
        <li>
            <button type="button" class="dropdown-item d-flex align-items-center @(TS.IsLight ? "active" : null)"
                    @onmousedown="@(() => { ChooseOption(ThemeService.Themes.Light); ItemClicked = true; })"
                    aria-pressed="@TS.IsLight">
                <i class="bi @IconLight me-2" aria-hidden="true"></i>
                Light
                <i class="bi bi-check-lg ms-auto @(TS.IsLight ? "" : "d-none")" aria-hidden="true"></i>
            </button>
        </li>

        <li>
            <button type="button" class="dropdown-item d-flex align-items-center @(TS.IsDark ? "active" : null)"
                    @onmousedown="@(() => { ChooseOption(ThemeService.Themes.Dark); ItemClicked = true; })"
                    aria-pressed="@TS.IsDark">
                <i class="bi @IconDark me-2" aria-hidden="true"></i>
                Dark
                <i class="bi bi-check-lg ms-auto @(TS.IsDark ? "" : "d-none")" aria-hidden="true"></i>
            </button>
        </li>

        <li>
            <button type="button" class="dropdown-item d-flex align-items-center @(TS.IsAuto ? "active" : null)"
                    @onmousedown="@(() => { ChooseOption(ThemeService.Themes.Auto); ItemClicked = true; })"
                    aria-pressed="@TS.IsAuto">
                <i class="bi @IconAuto me-2" aria-hidden="true"></i>
                Auto
                <i class="bi bi-check-lg ms-auto @(TS.IsAuto ? "" : "d-none")" aria-hidden="true"></i>
            </button>
        </li>
    </ul>
</div>

@code {
    [Parameter] public string cClass { get; set; } = "btn-outline-primary";

    private string IconLight = "bi-brightness-high-fill";
    private string IconDark = "bi-moon-fill";
    private string IconAuto = "bi-circle-half";

    protected override void OnInitialized()
    {
        TS.OnThemeChange += UpdateIcon;
        UpdateIcon(TS.Theme);
    }

    public void Dispose() => TS.OnThemeChange -= UpdateIcon;

    private bool IsOpen { get; set; } = false;

    private void Toggle() => IsOpen = !IsOpen;

    private void Close() => IsOpen = false;

    private async void ChooseOption(ThemeService.Themes theme)
    {
        Close();
        await TS.SelectTheme(theme);
    }

    private string icon = "";
    private string ariaTheme = "";
    private void UpdateIcon(ThemeService.Themes theme)
    {
        switch (theme)
        {
            case ThemeService.Themes.Auto:
                icon = IconAuto;
                ariaTheme = "Toggle theme (Auto)";
                break;

            case ThemeService.Themes.Light:
                icon = IconLight;
                ariaTheme = "Toggle theme (Light)";
                break;

            case ThemeService.Themes.Dark:
                icon = IconDark;
                ariaTheme = "Toggle theme (Dark)";
                break;
        }
        StateHasChanged();
    }

    // Source - https://stackoverflow.com/a/77128003
    // Posted by mpoust
    // Retrieved 2026-07-15, License - CC BY-SA 4.0

    private bool ItemClicked { get; set; } = false;
    private async Task PanelBlurred(FocusEventArgs e)
    {
        // Adjust based on use case
        await Task.Delay(100);

        if (!ItemClicked)
        {
            Close();
        }

        // reset for future clicks
        ItemClicked = false;
    }
}