@using ucc.Models

@inherits ItemBase

@namespace ucc.Components.Item

<div class="icon-container bg-body-tertiary" style="color: @color; width: @Size; height: @Size;" title="@Item.Name">
    @if (imageExists)
    {
        @* <img src="@($"{itemId}.jpg")" alt="@itemName" title="@itemName"> *@
        @* <img class="icon-item" src="favicon.png" alt="@itemName" draggable="false"> *@
    }
    else
    {
        <p class="icon-text p-0" title="@Item.Name">@GetDisplayName()</p>
    }
</div>

@code {
    [Parameter] public bool useFullName { get; set; } = false;
    [Parameter] public string? Size { get; set; } = "64px";

    private bool imageExists;
    private string color => Item.ColorHex;

    private string GetDisplayName()
    {
        if (Item.IsUnknown)
        {
            return "?";
        }

        return useFullName ? Item.Name : GetStringInitials(Item.Name);
    }

    private string GetStringInitials(string str)
    {
        string[]? words = str.Trim().Split(" ", StringSplitOptions.RemoveEmptyEntries);
        string initials = string.Join("", words.Select(w => w[0].ToString().ToUpper()));

        if (initials.Length == 1 && str.Length > 2)
        {
            initials += str[1].ToString().ToUpper();
            initials += str[2].ToString().ToUpper();
        }

        return initials;
    }
}
